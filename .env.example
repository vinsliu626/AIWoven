# Postgres (Prisma)
# For Neon/Supabase in app runtime, prefer the pooled/pgbouncer URL here.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require&pgbouncer=true&connection_limit=1"

# Direct connection for Prisma migrate/introspection (non-pooled).
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# App auth base URL and secret.
# Use the same host you log into locally, e.g. http://localhost:3000
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace_with_a_real_random_secret"

# Public site origin used for sitemap.xml, robots.txt, canonical tags, and Open Graph URLs.
# Set this in Vercel for production deployments.
NEXT_PUBLIC_SITE_URL="https://aiwoven.app"

# Public identity sent with OpenRouter requests.
OPENROUTER_APP_NAME="AIWoven"
OPENROUTER_SITE_URL="https://aiwoven.app"
# Ordered AI Note fallbacks used only after an eligible Groq provider failure.
# AI_NOTE_OPENROUTER_MODELS="nvidia/nemotron-3-super-120b-a12b:free,qwen/qwen3-next-80b-a3b-instruct:free,openai/gpt-oss-20b:free,meta-llama/llama-3.3-70b-instruct:free,openrouter/free"

# Stripe test mode keys and products.
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_PRO="price_..."
STRIPE_PRICE_ULTRA="price_..."

# Local-only convenience for server route testing without a browser session.
# When true outside production, billing API routes can use DEV_USER_EMAIL / dev_user.
DEV_BYPASS_AUTH="false"
DEV_USER_EMAIL="dev@local"

# AI detector service base URL (path defaults to /detect)
# Local default in code: http://127.0.0.1:8000
DETECTOR_URL="http://127.0.0.1:8000"
# Backward-compatible alias used by existing deployments
PY_DETECTOR_URL="http://127.0.0.1:8000/detect"
# Local-only convenience: allows /api/ai-detector without auth in non-production
AI_DETECTOR_DEV_BYPASS_AUTH="0"

# Promo code hashing secret (required in production for promo code redemption and promo:create)
# Add this exact env var in Vercel. Must be a real random secret; placeholder/default values are rejected.
PROMO_CODE_SECRET="Hello_world"

# Optional internal account allowlist for permanent premium bypass (comma-separated user ids/emails)
# PREMIUM_BYPASS_USER_IDS="me@example.com,internal@example.com"

# Study generation uses the first available provider in this order:
# GROQ -> DEEPSEEK -> KIMI
# GROQ_API_KEY=""
# HUMANIZER_GROQ_MODEL="llama-3.1-8b-instant"
# DEEPSEEK_API_KEY=""
# KIMI_API_KEY=""
# Owner access (comma-separated values are supported; configure at least one)
OWNER_EMAIL=
OWNER_USER_ID=

# Development/test browser authentication only. The provider is never registered in production.
# Copy these values to an ignored .env.development.local file, then run npm run dev:seed.
# Use reserved .test email addresses and unique local-only passwords.
E2E_AUTH_ENABLED=false
E2E_USER_EMAIL=
E2E_USER_PASSWORD=
E2E_OWNER_EMAIL=
E2E_OWNER_PASSWORD=

# Playwright uses the explicit URL first, otherwise 127.0.0.1 plus this port.
PLAYWRIGHT_BASE_URL=
PLAYWRIGHT_PORT=3000
