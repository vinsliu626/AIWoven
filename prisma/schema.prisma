generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum PromoCodeType {
  LIMITED
  INTERNAL
}

enum PromoTargetPlan {
  PRO
  ULTRA
}

enum UserRole {
  USER
  OWNER
}

/// *
/// * ===================== Chat =====================
model ChatSession {
  id        String        @id @default(cuid())
  userId    String
  title     String        @default("新的对话")
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  pinned    Boolean       @default(false)
  messages  ChatMessage[]

  @@index([userId, pinned, updatedAt])
  @@index([userId, updatedAt])
}

model ChatMessage {
  id            String      @id @default(cuid())
  chatSessionId String
  role          String
  content       String
  createdAt     DateTime    @default(now())
  chatSession   ChatSession @relation(fields: [chatSessionId], references: [id], onDelete: Cascade)

  @@index([chatSessionId, createdAt])
}

/// *
/// * ===================== Billing / Plans =====================
model UserEntitlement {
  userId                    String            @unique
  plan                      String            @default("basic")
  createdAt                 DateTime          @default(now())
  updatedAt                 DateTime          @updatedAt
  stripeCustomerId          String?
  stripeStatus              String?
  stripeSubId               String?
  id                        String            @id @default(cuid())
  canSeeSuspiciousSentences Boolean           @default(false)
  chatPerDay                Int?
  detectorWordsPerWeek      Int?
  noteSecondsPerWeek        Int?
  unlimited                 Boolean           @default(false)
  cancelAtPeriodEnd         Boolean?          @default(false)
  currentPeriodEnd          DateTime?
  dailyUsageKey             String?
  unlimitedSource           String?
  weeklyUsageKey            String?
  usedChatCountToday        Int               @default(0)
  usedDetectorWordsThisWeek Int               @default(0)
  usedNoteSecondsThisWeek   Int               @default(0)
  developerBypass           Boolean           @default(false)
  developerBypassSetAt      DateTime?
  developerBypassNote       String?
  promoPlan                 String?
  promoAccessStartAt        DateTime?
  promoAccessEndAt          DateTime?
  promoAccessActive         Boolean           @default(false)
  promoRedemptions          PromoRedemption[]
  role                      UserRole          @default(USER)

  @@index([developerBypass])
  @@index([promoAccessActive, promoAccessEndAt])
}

model ProcessedStripeEvent {
  id        String   @id @default(cuid())
  eventId   String   @unique
  type      String
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model GiftCode {
  code        String               @id
  isActive    Boolean              @default(true)
  maxUses     Int?
  usedCount   Int                  @default(0)
  createdAt   DateTime             @default(now())
  redemptions GiftCodeRedemption[]

  @@index([isActive])
}

model GiftCodeRedemption {
  id        String   @id @default(cuid())
  code      String
  userId    String
  createdAt DateTime @default(now())
  giftCode  GiftCode @relation(fields: [code], references: [code])

  @@unique([code, userId])
  @@index([userId])
  @@index([code, createdAt])
}

model PromoCode {
  id                String            @id @default(cuid())
  codeHash          String            @unique
  codeType          PromoCodeType     @default(LIMITED)
  targetPlan        PromoTargetPlan   @default(PRO)
  startsAt          DateTime?
  expiresAt         DateTime?
  grantDurationDays Int?
  grantFixedEndsAt  DateTime?
  maxRedemptions    Int?
  redeemedCount     Int               @default(0)
  perUserLimit      Int               @default(1)
  isActive          Boolean           @default(true)
  notes             String?
  createdBy         String?
  lastRedeemedAt    DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  redemptions       PromoRedemption[]

  @@index([isActive, expiresAt])
  @@index([createdAt])
}

model PromoRedemption {
  id           String          @id @default(cuid())
  promoCodeId  String
  userId       String
  redeemedAt   DateTime        @default(now())
  grantedPlan  PromoTargetPlan @default(PRO)
  grantStartAt DateTime
  grantEndAt   DateTime?
  grantStatus  String          @default("active")
  promoCode    PromoCode       @relation(fields: [promoCodeId], references: [id], onDelete: Restrict)
  entitlement  UserEntitlement @relation(fields: [userId], references: [userId], onDelete: Restrict)

  @@index([promoCodeId, redeemedAt])
  @@index([userId, redeemedAt])
}

model UsageEvent {
  id        String   @id @default(cuid())
  userId    String
  type      String
  amount    Int
  createdAt DateTime @default(now())

  @@index([userId, type, createdAt])
  @@index([createdAt])
}

/// *
/// * ===================== Internal Analytics =====================
model FeatureUsageEvent {
  id                 String   @id @default(cuid())
  userId             String?  @map("user_id")
  anonymousVisitorId String?  @map("anonymous_visitor_id")
  sessionId          String?  @map("session_id")
  featureKey         String   @map("feature_key")
  featureName        String   @map("feature_name")
  pagePath           String?  @map("page_path")
  actionType         String   @map("action_type")
  metadata           Json?
  success            Boolean  @default(true)
  errorMessage       String?  @map("error_message")
  userAgent          String?  @map("user_agent")
  ipHash             String?  @map("ip_hash")
  createdAt          DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@index([featureKey, createdAt])
  @@index([userId, createdAt])
  @@index([anonymousVisitorId, createdAt])
  @@index([sessionId, createdAt])
  @@index([actionType, createdAt])
  @@map("feature_usage_events")
}

model DailyUserActivity {
  id               String   @id @default(cuid())
  userId           String   @map("user_id")
  activityDate     DateTime @map("activity_date") @db.Date
  firstSeenAt      DateTime @default(now()) @map("first_seen_at")
  lastSeenAt       DateTime @default(now()) @map("last_seen_at")
  sessionCount     Int      @default(1) @map("session_count")
  featureCallCount Int      @default(0) @map("feature_call_count")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@unique([userId, activityDate])
  @@index([activityDate])
  @@index([lastSeenAt])
  @@map("daily_user_activity")
}

model FeatureDailyStat {
  id           String   @id @default(cuid())
  featureKey   String   @map("feature_key")
  featureName  String   @map("feature_name")
  statDate     DateTime @map("stat_date") @db.Date
  totalCalls   Int      @default(0) @map("total_calls")
  uniqueUsers  Int      @default(0) @map("unique_users")
  successCount Int      @default(0) @map("success_count")
  errorCount   Int      @default(0) @map("error_count")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@unique([featureKey, statDate])
  @@index([statDate])
  @@index([featureKey])
  @@map("feature_daily_stats")
}

model StudySession {
  id                String   @id @default(cuid())
  userId            String
  title             String
  fileName          String?
  fileSizeBytes     Int?
  mimeType          String?
  selectedModes     String[]
  selectedQuizTypes String[]
  resultJson        Json?
  status            String   @default("COMPLETED")
  errorSummary      String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  flashcardSet      FlashcardSet?

  @@index([userId, updatedAt])
  @@index([userId, createdAt])
}

/// Manually authored study material. Kept separate from AI-generated StudySession
/// records so existing generated results remain backward compatible.
model FlashcardSet {
  id             String        @id @default(cuid())
  userId         String
  title          String
  studySessionId String?       @unique
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  cards          Flashcard[]
  studySession   StudySession? @relation(fields: [studySessionId], references: [id], onDelete: SetNull)

  @@index([userId, updatedAt])
  @@index([userId, createdAt])
}

model Flashcard {
  id        String           @id @default(cuid())
  setId     String
  frontText String
  backText  String
  position  Int
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  set       FlashcardSet     @relation(fields: [setId], references: [id], onDelete: Cascade)
  images    FlashcardImage[]

  @@unique([setId, position])
  @@index([setId])
}

model FlashcardImage {
  id        String    @id @default(cuid())
  cardId    String
  side      String
  fileName  String
  mimeType  String
  sizeBytes Int
  data      Bytes
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  card      Flashcard @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@unique([cardId, side])
  @@index([cardId])
}

/// *
/// * ===================== AI Note =====================
model AiNoteSession {
  id          String              @id @default(cuid())
  userId      String
  createdAt   DateTime            @default(now())
  aiNoteJobId String?
  chunks      AiNoteChunk[]
  job         AiNoteJob?          @relation(fields: [aiNoteJobId], references: [id])
  summaries   AiNoteSummaryPart[]
  transcripts AiNoteTranscript[]

  @@index([userId, createdAt])
}

model AiNoteChunk {
  id         String        @id @default(cuid())
  noteId     String
  chunkIndex Int
  mime       String
  size       Int
  data       Bytes
  createdAt  DateTime      @default(now())
  session    AiNoteSession @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@unique([noteId, chunkIndex])
  @@index([noteId])
}

model AiNoteTranscript {
  id            String        @id @default(cuid())
  noteId        String
  chunkIndex    Int
  text          String
  rawText       String?
  canonicalText String?
  rawHash       String?
  canonicalHash String?
  asrProvider   String?
  asrModel      String?
  asrEndpoint   String?
  createdAt     DateTime      @default(now())
  session       AiNoteSession @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@unique([noteId, chunkIndex])
  @@index([noteId])
}

model AiNoteSummaryPart {
  id        String        @id @default(cuid())
  noteId    String
  partIndex Int
  text      String
  createdAt DateTime      @default(now())
  session   AiNoteSession @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@unique([noteId, partIndex])
  @@index([noteId])
}

model AiNoteJob {
  id                      String          @id @default(cuid())
  noteId                  String          @unique
  userId                  String
  stage                   String          @default("prep")
  progress                Int             @default(0)
  error                   String?
  updatedAt               DateTime        @updatedAt
  createdAt               DateTime        @default(now())
  asrNextIndex            Int             @default(0)
  llmNextPart             Int             @default(0)
  llmPartsTotal           Int             @default(0)
  noteMarkdown            String?
  secondsBilled           Int?
  rawTranscriptHash       String?
  canonicalTranscriptHash String?
  segmentTimeSec          Int             @default(300)
  segmentsTotal           Int             @default(0)
  lockExpiresAt           DateTime?
  lockedAt                DateTime?
  lockedBy                String?
  AiNoteSession           AiNoteSession[]

  @@index([noteId])
  @@index([lockedBy])
}
